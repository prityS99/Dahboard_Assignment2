<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Account | OTP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { 
            background: radial-gradient(circle at top right, #1e293b, #0f172a); 
            color: white; 
            min-height: 100vh; 
            display: flex; 
            align-items: center; 
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .otp-input {
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid #334155;
            color: #3b82f6;
            font-size: 2rem;
            font-weight: bold;
            letter-spacing: 10px;
            text-align: center;
            border-radius: 12px;
        }
        .otp-input:focus {
            background: #1e293b;
            color: white;
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="glass-card text-center">
                    <div class="mb-4">
                        <h2 class="fw-bold">Verify Email</h2>
                        <p class="text-secondary small">Enter the OTP sent to your inbox</p>
                    </div>

                    <form id="verifyForm">
                        <div class="mb-3 text-start">
                            <label class="form-label small text-secondary">Email Address</label>
                            <input type="email" id="email" class="form-control bg-dark text-white border-secondary" readonly>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small text-secondary">OTP Code</label>
                            <input type="text" id="otp" class="form-control otp-input" placeholder="000000" maxlength="6" required>
                        </div>
                        <button type="submit" class="btn btn-info w-100 fw-bold py-2 text-white shadow-sm">Verify Account</button>
                    </form>

                    <div class="mt-4">
                        <p class="small text-secondary">Didn't receive a code? 
                            <a href="#" class="text-info text-decoration-none fw-bold">Resend OTP</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 1. Auto-fill email from URL query (?email=user@example.com)
        const urlParams = new URLSearchParams(window.location.search);
        const emailParam = urlParams.get('email');
        if (emailParam) {
            document.getElementById('email').value = emailParam;
        }

        // 2. Handle Form Submission
        document.getElementById('verifyForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = document.getElementById('email').value;
            const otp = document.getElementById('otp').value;

            try {
                const response = await fetch('/api/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, otp })
                });

                const result = await response.json();

                if (result.success) {
                    alert("Email verified successfully! You can now login.");
                    window.location.href = '/'; // Redirect to login
                } else {
                    alert(result.message || "Verification failed");
                }
            } catch (error) {
                console.error("Error:", error);
                alert("Something went wrong!");
            }
        });
    </script>
</body>
</html>