<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Directory</title>
    <script>
      if (!localStorage.getItem("token")) {
        window.location.href = "/";
      }
    </script>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        background: #0f172a;
        color: white;
        min-height: 100vh;
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 1.5rem;
        transition: all 0.3s ease;
      }
      .glass-card:hover {
        transform: scale(1.02);
        background: rgba(255, 255, 255, 0.1);
      }
      .user-img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 50%;
        border: 2px solid #0dcaf0;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-dark border-bottom border-secondary mb-4">
      <div class="container">
        <span class="navbar-brand fw-bold text-info">USER DIRECTORY</span>
        <button
          onclick="handleLogout()"
          class="btn btn-outline-danger btn-sm rounded-pill"
        >
          Logout
        </button>
      </div>
    </nav>

  <div class="container">
  <div id="userInfo" class="row justify-content-center">
    <div class="col-12 text-center">
      <div class="spinner-border text-info" role="status"></div>
    </div>
  </div>
</div>

<script>
  async function displayUserProfile() {
    const container = document.getElementById("userInfo");
    
    // 1. Get user data saved during login
    const savedUser = JSON.parse(localStorage.getItem("user"));
    const token = localStorage.getItem("token");

    if (!savedUser || !token) {
        window.location.href = "/";
        return;
    }

    // 2. Render immediately from localStorage for a fast UI
    renderSingleUser(savedUser);

    // 3. Optional: Fetch fresh data from backend to ensure token is still valid
    try {
      const response = await fetch("/api/profile", { // Change this to your profile endpoint
        headers: {
          Authorization: `Bearer ${token}`,
          "Content-Type": "application/json",
        },
      });
      const result = await response.json();

      if (result.success) {
        renderSingleUser(result.user);
      } else if (result.message === "invalid token") {
        handleLogout();
      }
    } catch (err) {
      console.error("Session verification failed:", err);
    }
  }

  function renderSingleUser(user) {
    const container = document.getElementById("userInfo");
    const imageUrl = user.profileImage?.url || "https://via.placeholder.com/150";

    container.innerHTML = `
        <div class="col-md-6 col-lg-5">
            <div class="glass-card text-center">
                <img src="${imageUrl}" class="user-img shadow mb-3" style="width: 120px; height: 120px;" alt="${user.name}">
                <h3 class="fw-bold text-info">${user.name}</h3>
                <p class="text-secondary">${user.email}</p>
                <div class="d-flex justify-content-center gap-2 mt-3">
                    <span class="badge bg-info text-dark rounded-pill px-3">${user.role.toUpperCase()}</span>
                    <span class="badge border border-info text-info rounded-pill px-3">Active</span>
                </div>
                <hr class="my-4 border-secondary">
                <div class="text-start small text-secondary">
                    <p><strong>User ID:</strong> ${user._id}</p>
                    <p><strong>Account Status:</strong> Verified ✅</p>
                </div>
            </div>
        </div>
    `;
  }

  function handleLogout() {
    localStorage.clear();
    window.location.href = "/";
  }

  document.addEventListener("DOMContentLoaded", displayUserProfile);
</script>


  </body>
</html>
